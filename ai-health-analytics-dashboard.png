<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0b1220"/><stop offset="100%" stop-color="#10182a"/></linearGradient>
      <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#172238"/><stop offset="100%" stop-color="#1d2b45"/></linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#000000" flood-opacity="0.35"/></filter>
      <style>.title { font: 700 34px Arial, sans-serif; fill: #e8eefc; } .subtitle { font: 400 18px Arial, sans-serif; fill: #9fb0d0; } .box { fill: url(#panelGrad); stroke: #2a3a5a; stroke-width: 2; rx: 20; filter: url(#shadow); } .label { font: 700 20px Arial, sans-serif; fill: #e8eefc; } .body { font: 400 15px Arial, sans-serif; fill: #d7e1f5; } .small { font: 400 13px Arial, sans-serif; fill: #9fb0d0; } .line { stroke: #6ea8fe; stroke-width: 3; fill: none; }</style>
    </defs><rect width="100%" height="100%" fill="url(#bgGrad)"/>
<text x="50" y="55" class="title">AI Health Analytics Dashboard</text>
<text x="50" y="85" class="subtitle">Executive view of claims operations, automation performance, fraud exposure, and SLA risk</text>
<rect x="50" y="120" width="250" height="120" class="box"/><text x="75" y="160" class="small">Claims Turnaround Time</text><text x="75" y="210" class="title" style="font-size:44px;">2.8 Days</text><text x="75" y="230" class="body">40% faster</text>
<rect x="330" y="120" width="250" height="120" class="box"/><text x="355" y="160" class="small">Adjudication Accuracy</text><text x="355" y="210" class="title" style="font-size:44px;">96.2%</text><text x="355" y="230" class="body">30% improved</text>
<rect x="610" y="120" width="250" height="120" class="box"/><text x="635" y="160" class="small">Denial / Rework Rate</text><text x="635" y="210" class="title" style="font-size:44px;">8.4%</text><text x="635" y="230" class="body">25% lower</text>
<rect x="890" y="120" width="260" height="120" class="box"/><text x="915" y="160" class="small">Fraud Alerts</text><text x="915" y="210" class="title" style="font-size:44px;">43</text><text x="915" y="230" class="body">11 under review</text>
<rect x="50" y="280" width="680" height="340" class="box"/>
<text x="78" y="320" class="label">Claims Volume Trend</text><text x="78" y="347" class="small">Weekly processed claims vs exception queue</text>
<polyline points="100,540 180,490 260,470 340,430 420,410 500,360 580,330 660,300" class="line"/>
<polyline points="100,560 180,555 260,540 340,520 420,510 500,500 580,485 660,470" stroke="#ffc857" stroke-width="3" fill="none"/>
<line x1="95" y1="570" x2="680" y2="570" stroke="#42557a" stroke-width="2"/><line x1="100" y1="355" x2="100" y2="570" stroke="#42557a" stroke-width="2"/>
<text x="540" y="320" class="body">Processed Claims</text><text x="560" y="490" class="body">Exceptions</text>
<rect x="760" y="280" width="390" height="160" class="box"/>
<text x="788" y="320" class="label">Operational Priorities</text>
<text x="788" y="355" class="body">Top focus: specialty backlog</text><text x="788" y="383" class="body">Improve provider submission quality</text><text x="788" y="411" class="body">Tune fraud thresholds</text>
<rect x="760" y="460" width="390" height="160" class="box"/>
<text x="788" y="500" class="label">Governance Status</text><text x="788" y="535" class="body">Monthly budget: On track</text><text x="788" y="563" class="body">Open high risks: 2</text><text x="788" y="591" class="body">UAT readiness: 93%</text>
</svg>