<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0b1220"/><stop offset="100%" stop-color="#10182a"/></linearGradient>
      <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#172238"/><stop offset="100%" stop-color="#1d2b45"/></linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#000000" flood-opacity="0.35"/></filter>
      <style>.title { font: 700 34px Arial, sans-serif; fill: #e8eefc; } .subtitle { font: 400 18px Arial, sans-serif; fill: #9fb0d0; } .box { fill: url(#panelGrad); stroke: #2a3a5a; stroke-width: 2; rx: 20; filter: url(#shadow); } .label { font: 700 20px Arial, sans-serif; fill: #e8eefc; } .body { font: 400 15px Arial, sans-serif; fill: #d7e1f5; } .small { font: 400 13px Arial, sans-serif; fill: #9fb0d0; } .line { stroke: #6ea8fe; stroke-width: 3; fill: none; }</style>
    </defs><rect width="100%" height="100%" fill="url(#bgGrad)"/><text x="50" y="55" class="title">Claims Adjudication Process</text><text x="50" y="85" class="subtitle">Decisioning sequence used to validate, route, adjudicate, and settle healthcare claims</text><rect x="60" y="170" width="160" height="120" class="box"/><circle cx="88" cy="200" r="8" fill="#6ea8fe"/><text x="108" y="208" class="label">1. Intake</text><text x="82" y="242" class="body">Receive claim</text><text x="82" y="268" class="body">Assign trace ID</text><rect x="250" y="170" width="160" height="120" class="box"/><circle cx="278" cy="200" r="8" fill="#6dd3a0"/><text x="298" y="208" class="label">2. Validate</text><text x="272" y="242" class="body">Required fields</text><text x="272" y="268" class="body">Coding checks</text><rect x="440" y="170" width="160" height="120" class="box"/><circle cx="468" cy="200" r="8" fill="#ffc857"/><text x="488" y="208" class="label">3. Verify Coverage</text><text x="462" y="242" class="body">Member eligibility</text><text x="462" y="268" class="body">Contract rules</text><rect x="650" y="380" width="160" height="120" class="box"/><circle cx="678" cy="410" r="8" fill="#6ea8fe"/><text x="698" y="418" class="label">4. Decision</text><text x="672" y="452" class="body">Approve / pend / deny</text><text x="672" y="478" class="body">Apply edits</text><rect x="840" y="380" width="160" height="120" class="box"/><circle cx="868" cy="410" r="8" fill="#ff7a7a"/><text x="888" y="418" class="label">5. Review Exceptions</text><text x="862" y="452" class="body">Manual assessment</text><text x="862" y="478" class="body">Escalation if needed</text><rect x="1030" y="380" width="160" height="120" class="box"/><circle cx="1058" cy="410" r="8" fill="#6dd3a0"/><text x="1078" y="418" class="label">6. Settle</text><text x="1052" y="452" class="body">Payment posted</text><text x="1052" y="478" class="body">Audit trail complete</text><line x1="140" y1="230" x2="250" y2="230" class="line"/><polygon points="250,230 238.0,224.0 238.0,236.0" fill="#6ea8fe"/><text x="195.0" y="222.0" class="small" text-anchor="middle">next</text><line x1="330" y1="230" x2="440" y2="230" class="line"/><polygon points="440,230 428.0,224.0 428.0,236.0" fill="#6ea8fe"/><text x="385.0" y="222.0" class="small" text-anchor="middle">next</text><line x1="520" y1="230" x2="650" y2="440" class="line"/><polygon points="650,440 648.7853355047316,426.6386905520479 638.5821537444772,432.9549459274435" fill="#6ea8fe"/><text x="585.0" y="327.0" class="small" text-anchor="middle">next</text><line x1="730" y1="440" x2="840" y2="440" class="line"/><polygon points="840,440 828.0,434.0 828.0,446.0" fill="#6ea8fe"/><text x="785.0" y="432.0" class="small" text-anchor="middle">next</text><line x1="920" y1="440" x2="1030" y2="440" class="line"/><polygon points="1030,440 1018.0,434.0 1018.0,446.0" fill="#6ea8fe"/><text x="975.0" y="432.0" class="small" text-anchor="middle">next</text><rect x="760" y="170" width="320" height="120" class="box"/><text x="790" y="210" class="label">Decision Rules</text><text x="790" y="240" class="body">Policy coverage | contract terms</text><text x="790" y="268" class="body">Medical necessity | duplicate claim edits</text><rect x="60" y="560" width="1080" height="80" class="box"/><text x="90" y="605" class="body">Outputs: approved, denied, pended, manual review, payment disposition, and complete audit history</text></svg>