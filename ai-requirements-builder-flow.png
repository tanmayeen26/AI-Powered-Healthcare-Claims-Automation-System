<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0b1220"/><stop offset="100%" stop-color="#10182a"/></linearGradient>
      <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#172238"/><stop offset="100%" stop-color="#1d2b45"/></linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#000000" flood-opacity="0.35"/></filter>
      <style>.title { font: 700 34px Arial, sans-serif; fill: #e8eefc; } .subtitle { font: 400 18px Arial, sans-serif; fill: #9fb0d0; } .box { fill: url(#panelGrad); stroke: #2a3a5a; stroke-width: 2; rx: 20; filter: url(#shadow); } .label { font: 700 20px Arial, sans-serif; fill: #e8eefc; } .body { font: 400 15px Arial, sans-serif; fill: #d7e1f5; } .small { font: 400 13px Arial, sans-serif; fill: #9fb0d0; } .line { stroke: #6ea8fe; stroke-width: 3; fill: none; }</style>
    </defs><rect width="100%" height="100%" fill="url(#bgGrad)"/><text x="50" y="55" class="title">AI Requirements Builder Flow</text><text x="50" y="85" class="subtitle">How stakeholder inputs are transformed into delivery-ready requirements and controls</text><rect x="70" y="220" width="220" height="130" class="box"/><circle cx="98" cy="250" r="8" fill="#6ea8fe"/><text x="118" y="258" class="label">Stakeholder Inputs</text><text x="92" y="292" class="body">JAD sessions</text><text x="92" y="318" class="body">Pain points and goals</text><text x="92" y="344" class="body">Policies and SOPs</text><rect x="360" y="220" width="220" height="130" class="box"/><circle cx="388" cy="250" r="8" fill="#6dd3a0"/><text x="408" y="258" class="label">AI Parsing Layer</text><text x="382" y="292" class="body">Intent extraction</text><text x="382" y="318" class="body">Context grouping</text><text x="382" y="344" class="body">Gap prompts</text><rect x="650" y="130" width="220" height="110" class="box"/><circle cx="678" cy="160" r="8" fill="#6ea8fe"/><text x="698" y="168" class="label">BRD Draft</text><text x="672" y="202" class="body">Problem statement</text><text x="672" y="228" class="body">Scope, objectives</text><rect x="650" y="270" width="220" height="110" class="box"/><circle cx="678" cy="300" r="8" fill="#ffc857"/><text x="698" y="308" class="label">User Stories</text><text x="672" y="342" class="body">Stories, epics</text><text x="672" y="368" class="body">Acceptance criteria</text><rect x="650" y="410" width="220" height="110" class="box"/><circle cx="678" cy="440" r="8" fill="#ff7a7a"/><text x="698" y="448" class="label">Risk and Dependencies</text><text x="672" y="482" class="body">RAID prompts</text><text x="672" y="508" class="body">Open questions</text><rect x="940" y="220" width="200" height="150" class="box"/><circle cx="968" cy="250" r="8" fill="#6ea8fe"/><text x="988" y="258" class="label">BA and SME Review</text><text x="962" y="292" class="body">Validate accuracy</text><text x="962" y="318" class="body">Approve for backlog</text><text x="962" y="344" class="body">Refine release scope</text><line x1="290" y1="285" x2="360" y2="285" class="line"/><polygon points="360,285 348.0,279.0 348.0,291.0" fill="#6ea8fe"/><text x="325.0" y="277.0" class="small" text-anchor="middle">source text</text><line x1="580" y1="255" x2="650" y2="185" class="line"/><polygon points="650,185 637.2720779386422,189.2426406871193 645.7573593128808,197.72792206135787" fill="#6ea8fe"/><text x="615.0" y="212.0" class="small" text-anchor="middle">draft</text><line x1="580" y1="285" x2="650" y2="325" class="line"/><polygon points="650,325 642.5579159246474,313.8368738869712 636.6042486643655,324.25579159246473" fill="#6ea8fe"/><text x="615.0" y="297.0" class="small" text-anchor="middle">stories</text><line x1="580" y1="315" x2="650" y2="465" class="line"/><polygon points="650,465 650.3624732559981,451.5884895280701 639.488275576055,456.66311511204356" fill="#6ea8fe"/><text x="615.0" y="382.0" class="small" text-anchor="middle">risks</text><line x1="870" y1="185" x2="940" y2="285" class="line"/><polygon points="940,285 938.0338433907543,271.72844288759154 928.2030603445257,278.6099910199515" fill="#6ea8fe"/><line x1="870" y1="325" x2="940" y2="295" class="line"/><polygon points="940,295 926.6067438483083,294.2121614028417 931.3337754312583,305.24190176305837" fill="#6ea8fe"/><line x1="870" y1="465" x2="940" y2="305" class="line"/><polygon points="940,305 929.6932299823503,313.588975014708 940.6871180011766,318.39880102294455" fill="#6ea8fe"/><rect x="70" y="560" width="1070" height="80" class="box"/><text x="100" y="605" class="body">Benefits: faster documentation cycles | higher consistency | stronger traceability | better handoff to delivery and testing teams</text></svg>