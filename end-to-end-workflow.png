<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0b1220"/><stop offset="100%" stop-color="#10182a"/></linearGradient>
      <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#172238"/><stop offset="100%" stop-color="#1d2b45"/></linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#000000" flood-opacity="0.35"/></filter>
      <style>.title { font: 700 34px Arial, sans-serif; fill: #e8eefc; } .subtitle { font: 400 18px Arial, sans-serif; fill: #9fb0d0; } .box { fill: url(#panelGrad); stroke: #2a3a5a; stroke-width: 2; rx: 20; filter: url(#shadow); } .label { font: 700 20px Arial, sans-serif; fill: #e8eefc; } .body { font: 400 15px Arial, sans-serif; fill: #d7e1f5; } .small { font: 400 13px Arial, sans-serif; fill: #9fb0d0; } .line { stroke: #6ea8fe; stroke-width: 3; fill: none; }</style>
    </defs><rect width="100%" height="100%" fill="url(#bgGrad)"/><text x="50" y="55" class="title">End-to-End Claims Workflow</text><text x="50" y="85" class="subtitle">Target-state operating model from claim intake to reporting and continuous improvement</text><rect x="60" y="180" width="170" height="100" class="box"/><circle cx="88" cy="210" r="8" fill="#6ea8fe"/><text x="108" y="218" class="label">Claim Intake</text><text x="82" y="252" class="body">Provider portals</text><text x="82" y="278" class="body">Batch/API intake</text><rect x="260" y="180" width="170" height="100" class="box"/><circle cx="288" cy="210" r="8" fill="#6ea8fe"/><text x="308" y="218" class="label">Validation</text><text x="282" y="252" class="body">Eligibility checks</text><text x="282" y="278" class="body">Coding completeness</text><rect x="460" y="180" width="170" height="100" class="box"/><circle cx="488" cy="210" r="8" fill="#6ea8fe"/><text x="508" y="218" class="label">Classification</text><text x="482" y="252" class="body">AI triage</text><text x="482" y="278" class="body">Priority routing</text><rect x="660" y="180" width="170" height="100" class="box"/><circle cx="688" cy="210" r="8" fill="#6ea8fe"/><text x="708" y="218" class="label">Adjudication</text><text x="682" y="252" class="body">Rules + AI</text><text x="682" y="278" class="body">Auto decisioning</text><rect x="860" y="180" width="170" height="100" class="box"/><circle cx="888" cy="210" r="8" fill="#6ea8fe"/><text x="908" y="218" class="label">Payment</text><text x="882" y="252" class="body">Settlement</text><text x="882" y="278" class="body">Remittance advice</text><line x1="230" y1="230.0" x2="260" y2="230.0" class="line"/><polygon points="260,230.0 248.0,224.0 248.0,236.0" fill="#6ea8fe"/><line x1="430" y1="230.0" x2="460" y2="230.0" class="line"/><polygon points="460,230.0 448.0,224.0 448.0,236.0" fill="#6ea8fe"/><line x1="630" y1="230.0" x2="660" y2="230.0" class="line"/><polygon points="660,230.0 648.0,224.0 648.0,236.0" fill="#6ea8fe"/><line x1="830" y1="230.0" x2="860" y2="230.0" class="line"/><polygon points="860,230.0 848.0,224.0 848.0,236.0" fill="#6ea8fe"/><rect x="160" y="380" width="220" height="140" class="box"/><circle cx="188" cy="410" r="8" fill="#ffc857"/><text x="208" y="418" class="label">Exception Handling</text><text x="182" y="452" class="body">Incomplete claims</text><text x="182" y="478" class="body">Manual reviewer queue</text><rect x="470" y="380" width="220" height="140" class="box"/><circle cx="498" cy="410" r="8" fill="#ff7a7a"/><text x="518" y="418" class="label">Fraud Review</text><text x="492" y="452" class="body">Anomaly detection</text><text x="492" y="478" class="body">Compliance review</text><rect x="780" y="380" width="220" height="140" class="box"/><circle cx="808" cy="410" r="8" fill="#6dd3a0"/><text x="828" y="418" class="label">Reporting and Analytics</text><text x="802" y="452" class="body">SLA dashboard</text><text x="802" y="478" class="body">Trend insights</text><line x1="545" y1="280" x2="270" y2="380" class="line"/><polygon points="270,380 283.32797946038147,381.53784378389014 279.22706270334106,370.26032270202893" fill="#6ea8fe"/><text x="407.5" y="322.0" class="small" text-anchor="middle">If incomplete</text><line x1="745" y1="280" x2="580" y2="380" class="line"/><polygon points="580,380 593.3721842752083,378.91156639620397 587.152563682088,368.6491924175558" fill="#6ea8fe"/><text x="662.5" y="322.0" class="small" text-anchor="middle">If suspicious</text><line x1="930" y1="280" x2="890" y2="380" class="line"/><polygon points="890,380 900.0275482615608,371.0866237675015 888.8858279709376,366.6299356512523" fill="#6ea8fe"/><text x="910.0" y="322.0" class="small" text-anchor="middle">After settlement</text><rect x="60" y="560" width="1040" height="90" class="box"/><text x="90" y="600" class="label">Program Management Overlay</text><text x="90" y="628" class="body">RAID governance | UAT readiness | change management | reporting | training 