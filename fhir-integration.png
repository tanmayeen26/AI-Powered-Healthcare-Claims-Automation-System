<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
    <defs>
      <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0b1220"/><stop offset="100%" stop-color="#10182a"/></linearGradient>
      <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#172238"/><stop offset="100%" stop-color="#1d2b45"/></linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%"><feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#000000" flood-opacity="0.35"/></filter>
      <style>.title { font: 700 34px Arial, sans-serif; fill: #e8eefc; } .subtitle { font: 400 18px Arial, sans-serif; fill: #9fb0d0; } .box { fill: url(#panelGrad); stroke: #2a3a5a; stroke-width: 2; rx: 20; filter: url(#shadow); } .label { font: 700 20px Arial, sans-serif; fill: #e8eefc; } .body { font: 400 15px Arial, sans-serif; fill: #d7e1f5; } .small { font: 400 13px Arial, sans-serif; fill: #9fb0d0; } .line { stroke: #6ea8fe; stroke-width: 3; fill: none; }</style>
    </defs><rect width="100%" height="100%" fill="url(#bgGrad)"/><text x="50" y="55" class="title">FHIR Integration Architecture</text><text x="50" y="85" class="subtitle">Interoperability layer connecting provider systems, claims automation platform, and downstream services</text><rect x="60" y="170" width="220" height="120" class="box"/><circle cx="88" cy="200" r="8" fill="#6ea8fe"/><text x="108" y="208" class="label">Provider Systems</text><text x="82" y="242" class="body">EHR / EMR</text><text x="82" y="268" class="body">Provider portals</text><rect x="60" y="350" width="220" height="120" class="box"/><circle cx="88" cy="380" r="8" fill="#ffc857"/><text x="108" y="388" class="label">Clearinghouse</text><text x="82" y="422" class="body">Claims batches</text><text x="82" y="448" class="body">Response files</text><rect x="340" y="250" width="260" height="160" class="box"/><circle cx="368" cy="280" r="8" fill="#6dd3a0"/><text x="388" y="288" class="label">FHIR / API Gateway</text><text x="362" y="322" class="body">FHIR resources</text><text x="362" y="348" class="body">Auth, validation, mapping</text><rect x="670" y="140" width="220" height="120" class="box"/><circle cx="698" cy="170" r="8" fill="#6ea8fe"/><text x="718" y="178" class="label">Claims Engine</text><text x="692" y="212" class="body">Validation</text><text x="692" y="238" class="body">Adjudication</text><rect x="670" y="310" width="220" height="120" class="box"/><circle cx="698" cy="340" r="8" fill="#6ea8fe"/><text x="718" y="348" class="label">Member / Policy</text><text x="692" y="382" class="body">Eligibility data</text><text x="692" y="408" class="body">Coverage rules</text><rect x="950" y="140" width="200" height="120" class="box"/><circle cx="978" cy="170" r="8" fill="#6ea8fe"/><text x="998" y="178" class="label">Analytics</text><text x="972" y="212" class="body">KPIs</text><text x="972" y="238" class="body">Operational insights</text><rect x="950" y="310" width="200" height="120" class="box"/><circle cx="978" cy="340" r="8" fill="#ffc857"/><text x="998" y="348" class="label">Payment Systems</text><text x="972" y="382" class="body">Settlement</text><text x="972" y="408" class="body">Remittance</text><line x1="280" y1="230" x2="340" y2="300" class="line"/><polygon points="340,300 336.74604313272016,286.98417253088064 327.6349639043366,294.7936690123522" fill="#6ea8fe"/><text x="310.0" y="257.0" class="small" text-anchor="middle">FHIR Claim / Coverage</text><line x1="280" y1="410" x2="340" y2="350" class="line"/><polygon points="340,350 327.27207793864216,354.2426406871193 335.7573593128807,362.72792206135784" fill="#6ea8fe"/><text x="310.0" y="372.0" class="small" text-anchor="middle">Batch to API</text><line x1="600" y1="300" x2="670" y2="200" class="line"/><polygon points="670,200 658.2030603445257,206.3900089800485 668.0338433907543,213.27155711240846" fill="#6ea8fe"/><text x="635.0" y="242.0" class="small" text-anchor="middle">Normalized claim</text><line x1="600" y1="330" x2="670" y2="370" class="line"/><polygon points="670,370 662.5579159246474,358.8368738869712 656.6042486643655,369.25579159246473" fill="#6ea8fe"/><text x="635.0" y="342.0" class="small" text-anchor="middle">Eligibility lookup</text><line x1="890" y1="200" x2="950" y2="200" class="line"/><polygon points="950,200 938.0,194.0 938.0,206.0" fill="#6ea8fe"/><text x="920.0" y="192.0" class="small" text-anchor="middle">Data feed</text><line x1="890" y1="370" x2="950" y2="370" class="line"/><polygon points="950,370 938.0,364.0 938.0,376.0" fill="#6ea8fe"/><text x="920.0" y="362.0" class="small" text-anchor="middle">Approved claims</text><rect x="340" y="470" width="810" height="120" class="box"/><text x="370" y="510" class="label">Why FHIR Matters</text><text x="370" y="540" class="body">Standardized exchange improves interoperability, reduces custom mapping, accelerates onboarding, and strengthens auditability.</text></svg>